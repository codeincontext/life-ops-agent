# Copy to .env on the Beelink and set the two host paths.
# These are the paths AS THEY EXIST ON THE BEELINK, not on the Mac.

# The claude-admin project checkout (gives the session CLAUDE.md + skills).
PROJECT_PATH=/path/on/beelink/to/claude-admin

# The vault is NOT set here — it's a shared external Docker volume.
# Create it once:  docker volume create obsidian-vault
